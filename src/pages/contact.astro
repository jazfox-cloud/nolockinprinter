---
import SiteLayout from '../layouts/SiteLayout.astro';
import EmailLink from '../components/EmailLink.astro';
---

<SiteLayout
  title="Contact No Lock-In Printer"
  description="Contact No Lock-In Printer with corrections, printer lock-in reports, disclosure questions, or editorial feedback."
>
  <article class="article">
    <p class="eyebrow" style="color: var(--amber);">Contact</p>
    <h1>Send corrections, tips, and printer lock-in reports.</h1>
    <p class="lead">
      Have a correction, a source we should review, or a firmware or supply-locking issue to flag? Use this page as the public contact point for the site.
    </p>

    <section class="article-section">
      <h2>Email</h2>
      <p>
        Contact us at <EmailLink user="hello" domain="nolockinprinter.com" />. Email delivery and reply handling are operational checks performed by the site owner; this page does not claim a completed mailbox test.
      </p>
    </section>

    <section class="article-section">
      <h2>What to include</h2>
      <ul>
        <li>The exact printer model and region.</li>
        <li>Links to official documentation, support pages, or current retailer pages.</li>
        <li>Whether the issue involves subscriptions, firmware, third-party ink or toner, Linux support, or local network printing.</li>
      </ul>
    </section>
  </article>
</SiteLayout>
